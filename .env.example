# Copia este archivo a .env y ajusta los valores (no subas .env al repositorio).
#
# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=sife_mxn

# API (opcional)
# API_V1_PREFIX=/api/v1
# PROJECT_NAME=SIFE-MXN
API_KEY=cambia-esta-api-key
# API_KEY_HEADER=X-API-Key

# JWT (usuarios del panel / Bearer). Genera una clave larga y aleatoria en producción.
# JWT_SECRET_KEY=
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Dirección — ventana de edición de umbrales KPI (solo afecta PUT de override por usuario; admin sigue pudiendo gobernar por rol).
# DIRECCION_THRESHOLD_EDIT_WINDOW_ENABLED=false
# DIRECCION_THRESHOLD_EDIT_TIMEZONE=America/Mexico_City
# DIRECCION_THRESHOLD_EDIT_WEEKDAY_START=0
# DIRECCION_THRESHOLD_EDIT_WEEKDAY_END=4
# DIRECCION_THRESHOLD_EDIT_HOUR_START=9
# DIRECCION_THRESHOLD_EDIT_HOUR_END=18

# Dirección — snapshot comité vía cron (sin JWT; router /api/v1/internal, cabecera X-SIFE-Direccion-Cron-Secret).
# DIRECCION_COMMITTEE_SNAPSHOT_CRON_SECRET=
# DIRECCION_COMMITTEE_SNAPSHOT_CRON_ACTOR_USERNAME=
